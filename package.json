    "prepublishOnly": "npm run build",
    "release": "tsx scripts/release.ts"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@synergenius/flow-weaver": "^0.17.1"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
