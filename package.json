{
  "name": "@synergenius/flow-weaver-pack-vercel",
  "version": "0.1.2",
  "description": "Vercel Serverless Functions export target for Flow Weaver",
  "keywords": [
    "flow-weaver-marketplace-pack",
    "flow-weaver",
    "vercel",
    "serverless"
  ],
  "flowWeaver": {
    "type": "marketplace-pack",
    "engineVersion": ">=0.14.0",
    "categories": [
      "deployment",
      "serverless"
    ]
  },
  "peerDependencies": {
    "@synergenius/flow-weaver": ">=0.14.0"
  },
  "main": "./dist/target.js",
  "types": "./dist/target.d.ts",
